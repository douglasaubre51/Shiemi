<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Shiemi.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:signin="clr-namespace:Shiemi.Views"
    xmlns:signup="clr-namespace:Shiemi.Views"
    Shell.FlyoutBehavior="Flyout"
    BackgroundColor="{StaticResource BackgroundWhite}">

    <!--flyout items-->
    <FlyoutItem Title="Sign in">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate signin:SignInView}"
                          Route="SignInView"/>
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Sign up">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate signup:SignUpView}"
                          Route="SignUpView"/>
        </Tab>
    </FlyoutItem>

    <!-- footer -->
    <Shell.FlyoutFooter>
        <VerticalStackLayout
            Margin="20"
            VerticalOptions="Center"
            HorizontalOptions="Start">
            <Label Text="Shiemi"
                   FontSize="Header"/>
            <Label Text="by douglasaubre51"
                   FontSize="Caption"/>
        </VerticalStackLayout>
    </Shell.FlyoutFooter>
</Shell>