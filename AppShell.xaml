<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Shiemi.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Shiemi.Views"
    FlyoutBehavior="Flyout"
    Shell.NavBarIsVisible="False">

    <!--  flyout items  -->
    <FlyoutItem Title="Add new Project">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:CreateProjectView}" Route="CreateTemplateView" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Projects">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:ProjectView}" Route="ProjectView" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Profile">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:UserProfileView}" Route="UserProfileView" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Sign in">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:SignInView}" Route="SignInView" />
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Sign up">
        <Tab>
            <ShellContent ContentTemplate="{DataTemplate views:SignUpView}" Route="SignUpView" />
        </Tab>
    </FlyoutItem>

    <!--  footer  -->
    <Shell.FlyoutFooter>
        <VerticalStackLayout
            Margin="20"
            HorizontalOptions="Start"
            VerticalOptions="Center">
            <Label FontSize="Header" Text="Shiemi" />
            <Label FontSize="Caption" Text="by douglasaubre51" />
        </VerticalStackLayout>
    </Shell.FlyoutFooter>
</Shell>