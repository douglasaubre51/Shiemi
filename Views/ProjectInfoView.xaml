<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Shiemi.Views.ProjectInfoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:Shiemi.ViewModels"
    Title="ProjectInfoView"
    x:DataType="viewmodel:ProjectInfoVM"
    Shell.NavBarIsVisible="True">
    <VerticalStackLayout>
        <Label Text="{Binding Project.Title}" />
        <Label Text="{Binding Project.Description}" />
    </VerticalStackLayout>
</ContentPage>
