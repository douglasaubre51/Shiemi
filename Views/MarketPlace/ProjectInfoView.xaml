<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Shiemi.Views.ProjectInfoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:Shiemi.ViewModels"
    x:DataType="viewmodel:ProjectInfoVM"
    Shell.NavBarIsVisible="False">
    <!--  main layout  -->
    <Grid
        Margin="20,10,0,10"
        HorizontalOptions="Fill"
        RowDefinitions="*,Auto"
        RowSpacing="10"
        VerticalOptions="Fill">
        <ScrollView Orientation="Both">
            <VerticalStackLayout
                Grid.Row="0"
                HorizontalOptions="Fill"
                Spacing="20"
                VerticalOptions="Fill">
                <!--  title  -->
                <Label Style="{StaticResource primary-title-txt}" Text="{Binding Project.Title}" />
                <!--  text details  -->
                <Label
                    Margin="0,15,0,0"
                    Style="{StaticResource description-txt}"
                    Text="{Binding Project.Description}" />
            </VerticalStackLayout>
        </ScrollView>
        <!--  extras  -->
        <VerticalStackLayout
            Grid.Row="1"
            Margin="0,20,0,10"
            HorizontalOptions="Fill"
            Spacing="10"
            VerticalOptions="Fill">
            <Label Style="{StaticResource price-txt}" Text="{Binding Project.Price, StringFormat='estimated cost:  ${0}'}" />
            <Label Style="{StaticResource date-txt}" Text="{Binding Project.CreatedAt, StringFormat='created at:  {0}'}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
