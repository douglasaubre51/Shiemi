<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Shiemi.Views.ProjectInfoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:Shiemi.ViewModels"
    x:DataType="viewmodel:ProjectInfoVM"
    Shell.NavBarIsVisible="False">
    <!--  main layout  -->
    <ScrollView Orientation="Both">
        <Grid
            Margin="20,10,0,10"
            HorizontalOptions="Fill"
            RowDefinitions="*,3*,Auto"
            RowSpacing="10"
            VerticalOptions="Fill">
            <!--  title  -->
            <Label
                Grid.Row="0"
                Style="{StaticResource title-txt-details}"
                Text="{Binding Project.Title}" />
            <!--  desc  -->
            <Label
                Grid.Row="1"
                Margin="0,15,0,0"
                Style="{StaticResource description-txt-details}"
                Text="{Binding Project.Description}" />
            <!--  footer  -->
            <VerticalStackLayout
                Grid.Row="2"
                Margin="0,20,0,10"
                HorizontalOptions="Fill"
                Spacing="10"
                VerticalOptions="Fill">
                <!--  price  -->
                <Label Style="{StaticResource price-txt-details}" Text="{Binding Project.Price, StringFormat='estimated cost:  ${0}'}" />
                <!--  created date  -->
                <Label Style="{StaticResource date-txt-details}" Text="{Binding Project.CreatedAt, StringFormat='created at:  {0}'}" />
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
