<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Shiemi.Views.Project.ProjectDetailsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:Shiemi.ViewModels.Project"
    Title="ProjectDetailsView"
    x:DataType="viewmodel:ProjectDetailsVM">
    <VerticalStackLayout>
        <Label
            HorizontalOptions="Start"
            Style="{StaticResource primary-title-txt}"
            Text="{Binding Project.Title}"
            VerticalOptions="Start" />
    </VerticalStackLayout>
</ContentPage>
