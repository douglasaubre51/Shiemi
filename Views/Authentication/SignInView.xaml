<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Shiemi.Views.SignInView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModel="clr-namespace:Shiemi.ViewModels"
    x:DataType="viewModel:SignInVM">
    <!--  main layout  -->
    <ScrollView Orientation="Both">
        <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Center">
            <!--  card layout  -->
            <Border
                Margin="20"
                Padding="50,20,50,50"
                BackgroundColor="{StaticResource secondary-background-clr}"
                HorizontalOptions="Center"
                Style="{StaticResource card-shadow}"
                VerticalOptions="Center">
                <!--  form grid  -->
                <Grid
                    ColumnDefinitions="*"
                    ColumnSpacing="40"
                    HorizontalOptions="Fill"
                    RowDefinitions="*,4*,4*,*"
                    RowSpacing="15">
                    <!--  header tag  -->
                    <Label
                        Grid.Row="0"
                        HorizontalOptions="Start"
                        Style="{StaticResource header-tag}"
                        Text="Sign in"
                        VerticalOptions="Center" />

                    <!--  email  -->
                    <VerticalStackLayout Grid.Row="1">
                        <Label Style="{StaticResource entry-label}" Text="email" />
                        <Entry
                            Grid.Row="1"
                            Grid.Column="0"
                            ClearButtonVisibility="WhileEditing"
                            IsEnabled="{Binding IsNotBusy}"
                            Style="{StaticResource entry}"
                            Text="{Binding Email}" />
                        <Label Style="{StaticResource validation-msg}" Text="{Binding EmailValidationMessage}" />
                    </VerticalStackLayout>

                    <!--  password  -->
                    <VerticalStackLayout Grid.Row="2">
                        <Label Style="{StaticResource entry-label}" Text="password" />
                        <Entry
                            Grid.Row="1"
                            Grid.Column="0"
                            ClearButtonVisibility="WhileEditing"
                            IsEnabled="{Binding IsNotBusy}"
                            IsPassword="True"
                            Style="{StaticResource entry}"
                            Text="{Binding Password}" />
                        <Label Style="{StaticResource validation-msg}" Text="{Binding PasswordValidationMessage}" />
                    </VerticalStackLayout>

                    <!--  btn container  -->
                    <VerticalStackLayout
                        Grid.Row="3"
                        HorizontalOptions="Fill"
                        Spacing="15"
                        VerticalOptions="Center">
                        <!--  signin button  -->
                        <Button
                            Command="{Binding TriggerSignInCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            IsVisible="{Binding IsNotBusy}"
                            Style="{StaticResource primary-button}"
                            Text="continue" />

                        <!--  goto signup button  -->
                        <Button
                            Command="{Binding GoToSignUpViewCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            IsVisible="{Binding IsNotBusy}"
                            Style="{StaticResource tertiary-btn}"
                            Text="don't have an account?" />

                    </VerticalStackLayout>

                    <!--  spinner  -->
                    <ActivityIndicator
                        Grid.Row="3"
                        HorizontalOptions="End"
                        IsEnabled="{Binding IsBusy}"
                        IsRunning="{Binding IsBusy}"
                        Color="{StaticResource secondary-accent-clr}" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>