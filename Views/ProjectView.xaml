<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Shiemi.Views.ProjectView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:Shiemi.Models"
    xmlns:viewmodel="clr-namespace:Shiemi.ViewModels"
    x:DataType="viewmodel:ProjectVM">
    <Grid
        Margin="20"
        ColumnDefinitions="*"
        HorizontalOptions="Fill"
        RowDefinitions="100,*,Auto"
        RowSpacing="10"
        VerticalOptions="Fill">

        <!--  page title  -->
        <Label
            Grid.Row="0"
            HorizontalOptions="Start"
            Style="{StaticResource primary-title-txt}"
            Text="projects"
            VerticalOptions="Start" />

        <!--  project collection  -->
        <ScrollView Grid.Row="1" Orientation="Both">
            <CollectionView
                Grid.Row="1"
                HorizontalOptions="Fill"
                ItemsSource="{Binding Projects}"
                VerticalOptions="Fill">

                <!--  template  -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:ProjectModel">
                        <!--  item  -->
                        <Border
                            BackgroundColor="Transparent"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill">

                            <!--  tap event  -->
                            <Border.GestureRecognizers />

                            <!--  layout  -->
                            <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill">
                                <Label Text="{Binding Title}" />
                                <Label Text="{Binding ShortDescription}" />
                                <Label Text="{Binding Description}" />
                                <Label Text="{Binding EndsAt}" />
                            </VerticalStackLayout>

                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </ScrollView>

        <!--  add new project btn  -->
        <Button
            Grid.Row="2"
            Command="{Binding GoToCreateProjectViewCommand}"
            IsEnabled="{Binding IsNotBusy}"
            IsVisible="{Binding IsNotBusy}"
            Style="{StaticResource primary-button}"
            Text="new" />

        <!--  spinner  -->
        <ActivityIndicator
            Grid.Row="2"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}" />
    </Grid>
</ContentPage>
