<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Shiemi.Views.ProjectView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:Shiemi.Models"
    xmlns:viewmodel="clr-namespace:Shiemi.ViewModels"
    x:DataType="viewmodel:ProjectVM"
    BackgroundColor="{StaticResource primary-background-clr}"
    Shell.BackgroundColor="{StaticResource primary-background-clr}"
    Shell.NavBarIsVisible="True">
    <ContentPage.MenuBarItems>
        <MenuBarItem Text="File">
            <MenuFlyoutItem Command="{Binding GoToCreateProjectViewCommand}" Text="new" />
        </MenuBarItem>
        <MenuBarItem Text="Edit">
            <MenuFlyoutItem Text="remove selected items" />
        </MenuBarItem>
    </ContentPage.MenuBarItems>
    <!--  refresh btn  -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding FillProjectCollectionCommand}" Text="refresh" />
    </ContentPage.ToolbarItems>
    <!--  main grid  -->
    <Grid
        Margin="20"
        ColumnDefinitions="*"
        HorizontalOptions="Fill"
        RowDefinitions="*,Auto"
        RowSpacing="10"
        VerticalOptions="Fill">
        <!--  project collection  -->
        <Border
            Grid.Row="0"
            Margin="10,10,40,10"
            Style="{StaticResource primary-project-card}">
            <ScrollView Orientation="Both">
                <CollectionView
                    HorizontalOptions="Fill"
                    ItemsSource="{Binding Projects}"
                    VerticalOptions="Fill">
                    <!--  template  -->
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:ProjectModel">
                            <!--  item  -->
                            <Border
                                Margin="10,10,40,10"
                                BackgroundColor="{StaticResource fourth-background-clr}"
                                HorizontalOptions="Fill"
                                Style="{StaticResource primary-project-card}"
                                VerticalOptions="Fill">
                                <!--  tap event  -->
                                <Border.GestureRecognizers />
                                <!--  item layout  -->
                                <VerticalStackLayout
                                    Margin="20"
                                    HorizontalOptions="Fill"
                                    Spacing="10"
                                    VerticalOptions="Fill">
                                    <Label Style="{StaticResource secondary-title-txt}" Text="{Binding Title}" />
                                    <Label Text="{Binding ShortDescription}" />
                                    <Label Text="{Binding Price, StringFormat='$ {0}'}" />
                                    <Label HorizontalOptions="End" Text="{Binding CreatedAt, StringFormat='created at: {0}'}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>
        </Border>
        <!--  add new project btn  -->
        <Button
            Grid.Row="1"
            Command="{Binding GoToCreateProjectViewCommand}"
            IsEnabled="{Binding IsNotBusy}"
            IsVisible="{Binding IsNotBusy}"
            Style="{StaticResource primary-button}"
            Text="new" />
        <!--  spinner  -->
        <ActivityIndicator
            Grid.Row="2"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}" />
    </Grid>
</ContentPage>
