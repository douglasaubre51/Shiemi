<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Shiemi.Views.UserProfileView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModel="clr-namespace:Shiemi.ViewModels"
    x:DataType="viewModel:UserProfileVM">

    <Grid
        Margin="20"
        ColumnDefinitions="*,*"
        ColumnSpacing="20"
        HorizontalOptions="Fill"
        RowDefinitions="*"
        VerticalOptions="Fill">
        <VerticalStackLayout Grid.Column="0" Spacing="10">
            <Label Style="{StaticResource user-name-header}" Text="{Binding Username}" />
            <Label Style="{StaticResource user-name-header}" Text="{Binding Email}" />
            <Label Style="{StaticResource user-name-header}" Text="{Binding PhoneNo}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
