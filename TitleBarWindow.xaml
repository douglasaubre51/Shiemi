<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Shiemi.TitleBarWindow"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:Shiemi.ViewModels"
    Title="TitleBarWindow"
    x:DataType="viewmodel:BaseVM">
    <Window.TitleBar>
        <TitleBar Title="{Binding PageTitle}" />

    </Window.TitleBar>
</Window>